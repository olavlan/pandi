{"name":"pandoc_lustre_converter","version":"1.0.0","gleam-version-constraint":null,"modules":{"pandoc_lustre_converter":{"documentation":[" Module for converting a Pandoc document to a Lustre element, with support for custom conversion rules."," Complete example:","","```gleam"," import lustre/attribute"," import lustre/element"," import lustre/element/html"," import pandi/doc"," import pandoc_lustre_converter as pl"," "," pub fn main() {","   let block_converter: pl.BlockConverter(msg) = fn(block, _meta) {","     case block {","       doc.Div(_, [doc.Header(_, _, inlines), ..rest]) -> {","         use details <- pl.default_blocks(rest)","         use summary <- pl.default_inlines(inlines)","         html.details([], [","           html.summary([], [summary]),","           details,","         ])","         |> pl.custom","       }","       _ -> pl.default","     }","   }"," ","   let inline_converter: pl.InlineConverter(msg) = fn(inline, _meta) {","     case inline {","       doc.Str(\"#\" <> tag) ->","         html.a([attribute.href(\"/tags/\" <> tag)], [html.text(tag)]) |> pl.custom","       _ -> pl.default","     }","   }"," ","   let empty_attributes = doc.Attributes(\"\", [], [])","   let sample =","     doc.Document(","       blocks: [","         doc.Para(doc.text(\"A #tag is in this paragraph.\")),","         doc.Div(attributes: empty_attributes, content: [","           doc.Header(1, empty_attributes, doc.text(\"This is the summary\")),","           doc.Plain(doc.text(\"There is #another-tag in the details.\")),","         ]),","       ],","       meta: [],","     )"," ","   sample","   |> pl.convert_document(block_converter, inline_converter)","   |> element.to_readable_string","   // <p>","   //   A","   //   <a href=\"/tags/tag\">","   //     tag","   //   </a>","   //    is in this paragraph.","   // </p>","   // <details>","   //   <summary>","   //     This is the summary","   //   </summary>","   //   There is","   //   <a href=\"/tags/another-tag\">","   //     another-tag","   //   </a>","   //    in the details.","   // </details>"," }"," ```"],"type-aliases":{"BlockConverter":{"documentation":"A block converter is a function that takes a block\nand returns and action, where an action is constructed using \neither `default` (to convert the element in the default way)\nor `custom` (to convert to a custom Lustre element element.).\n\nExample:\n```gleam\n import lustre/element\n import pandi/doc\n\n // ...\n\n let block_converter: BlockConverter(msg) = fn(block, _meta) {\n   case block {\n     doc.Div(_, [doc.Header(_, _, inlines), ..rest]) -> {\n       use details <- default_blocks(rest)\n       use summary <- default_inlines(inlines)\n       html.details([], [\n         html.summary([], [summary]),\n         details,\n       ])\n       |> custom\n     }\n     _ -> default\n   }\n }\n ```\n","deprecation":null,"parameters":1,"alias":{"kind":"fn","parameters":[{"kind":"named","name":"Block","package":"pandi","module":"pandi/doc","parameters":[]},{"kind":"named","name":"List","package":"","module":"gleam","parameters":[{"kind":"tuple","elements":[{"kind":"named","name":"String","package":"","module":"gleam","parameters":[]},{"kind":"named","name":"String","package":"","module":"gleam","parameters":[]}]}]}],"return":{"kind":"named","name":"Action","package":"pandoc_lustre_converter","module":"pandoc_lustre_converter","parameters":[{"kind":"variable","id":0}]}}},"InlineConverter":{"documentation":"A block converter is a function that takes an inline\nand produces and action, where an action is constructed using \neither `default` (converting the element in the default way)\nor `custom` (to convert to a custom Lustre element element.).\n\nExample:\n\n```gleam\n import lustre/attribute\n import lustre/element\n import pandi/doc\n\n // ...\n\n let inline_converter: InlineConverter(msg) = fn(inline, _meta) {\n   case inline {\n     doc.Str(\"#\" <> tag) ->\n       html.a([attribute.href(\"/tags/\" <> tag)], [html.text(tag)]) |> custom\n     _ -> default\n   }\n }\n```\n","deprecation":null,"parameters":1,"alias":{"kind":"fn","parameters":[{"kind":"named","name":"Inline","package":"pandi","module":"pandi/doc","parameters":[]},{"kind":"named","name":"List","package":"","module":"gleam","parameters":[{"kind":"tuple","elements":[{"kind":"named","name":"String","package":"","module":"gleam","parameters":[]},{"kind":"named","name":"String","package":"","module":"gleam","parameters":[]}]}]}],"return":{"kind":"named","name":"Action","package":"pandoc_lustre_converter","module":"pandoc_lustre_converter","parameters":[{"kind":"variable","id":0}]}}}},"types":{"Action":{"documentation":"The type that converters should return.\nUse the provided constructors `default` and `custom`.\n","deprecation":null,"parameters":1,"constructors":[]}},"constants":{"default":{"documentation":"Action to convert a document element the default way.\n","deprecation":null,"implementations":{"gleam":true,"uses-erlang-externals":false,"uses-javascript-externals":false,"can-run-on-erlang":true,"can-run-on-javascript":true},"type":{"kind":"named","name":"Action","package":"pandoc_lustre_converter","module":"pandoc_lustre_converter","parameters":[{"kind":"variable","id":0}]}}},"functions":{"convert_attributes":{"documentation":" Convert document attributes to a list of Lustre attributes.\n","deprecation":null,"implementations":{"gleam":true,"uses-erlang-externals":true,"uses-javascript-externals":false,"can-run-on-erlang":true,"can-run-on-javascript":true},"parameters":[{"label":null,"type":{"kind":"named","name":"Attributes","package":"pandi","module":"pandi/doc","parameters":[]}}],"return":{"kind":"named","name":"List","package":"","module":"gleam","parameters":[{"kind":"named","name":"Attribute","package":"lustre","module":"lustre/vdom/vattr","parameters":[{"kind":"variable","id":0}]}]}},"convert_document":{"documentation":"Converts a document with the given block and inline converters.\n","deprecation":null,"implementations":{"gleam":false,"uses-erlang-externals":true,"uses-javascript-externals":true,"can-run-on-erlang":true,"can-run-on-javascript":true},"parameters":[{"label":null,"type":{"kind":"named","name":"Document","package":"pandi","module":"pandi/doc","parameters":[]}},{"label":null,"type":{"kind":"fn","parameters":[{"kind":"named","name":"Block","package":"pandi","module":"pandi/doc","parameters":[]},{"kind":"named","name":"List","package":"","module":"gleam","parameters":[{"kind":"tuple","elements":[{"kind":"named","name":"String","package":"","module":"gleam","parameters":[]},{"kind":"named","name":"String","package":"","module":"gleam","parameters":[]}]}]}],"return":{"kind":"named","name":"Action","package":"pandoc_lustre_converter","module":"pandoc_lustre_converter","parameters":[{"kind":"variable","id":0}]}}},{"label":null,"type":{"kind":"fn","parameters":[{"kind":"named","name":"Inline","package":"pandi","module":"pandi/doc","parameters":[]},{"kind":"named","name":"List","package":"","module":"gleam","parameters":[{"kind":"tuple","elements":[{"kind":"named","name":"String","package":"","module":"gleam","parameters":[]},{"kind":"named","name":"String","package":"","module":"gleam","parameters":[]}]}]}],"return":{"kind":"named","name":"Action","package":"pandoc_lustre_converter","module":"pandoc_lustre_converter","parameters":[{"kind":"variable","id":0}]}}}],"return":{"kind":"named","name":"Element","package":"lustre","module":"lustre/vdom/vnode","parameters":[{"kind":"variable","id":0}]}},"custom":{"documentation":"Action to convert a document element to a custom Lustre element.\n","deprecation":null,"implementations":{"gleam":true,"uses-erlang-externals":false,"uses-javascript-externals":false,"can-run-on-erlang":true,"can-run-on-javascript":true},"parameters":[{"label":null,"type":{"kind":"named","name":"Element","package":"lustre","module":"lustre/vdom/vnode","parameters":[{"kind":"variable","id":0}]}}],"return":{"kind":"named","name":"Action","package":"pandoc_lustre_converter","module":"pandoc_lustre_converter","parameters":[{"kind":"variable","id":0}]}},"default_blocks":{"documentation":"Use this when you need a custom conversion rule for a document element,\nbut you want some children of the document element to be\nconverted in the default way:\n```gleam\n import lustre/element\n import pandi/doc\n\n // ...\n\n let block_converter: BlockConverter(msg) = fn(block, _meta) {\n   case block {\n     doc.Div(_, [doc.Header(_, _, inlines), ..rest]) -> {\n       use details <- default_blocks(rest)\n       use summary <- default_inlines(inlines)\n       // `details` and `summary` are Lustre elements that can be used as building blocks:\n       html.details([], [\n         html.summary([], [summary]),\n         details,\n       ])\n       |> custom\n     }\n     _ -> default\n   }\n }\n ```\n","deprecation":null,"implementations":{"gleam":true,"uses-erlang-externals":true,"uses-javascript-externals":false,"can-run-on-erlang":true,"can-run-on-javascript":true},"parameters":[{"label":null,"type":{"kind":"named","name":"List","package":"","module":"gleam","parameters":[{"kind":"named","name":"Block","package":"pandi","module":"pandi/doc","parameters":[]}]}},{"label":null,"type":{"kind":"fn","parameters":[{"kind":"named","name":"Element","package":"lustre","module":"lustre/vdom/vnode","parameters":[{"kind":"variable","id":0}]}],"return":{"kind":"named","name":"Action","package":"pandoc_lustre_converter","module":"pandoc_lustre_converter","parameters":[{"kind":"variable","id":0}]}}}],"return":{"kind":"named","name":"Action","package":"pandoc_lustre_converter","module":"pandoc_lustre_converter","parameters":[{"kind":"variable","id":0}]}},"default_inlines":{"documentation":"Use this when you need a custom conversion rule for a document element,\nbut you want some children of the document element to be\nconverted in the default way:\n```gleam\n import lustre/element\n import pandi/doc\n\n // ...\n\n let block_converter: BlockConverter(msg) = fn(block, _meta) {\n   case block {\n     doc.Div(_, [doc.Header(_, _, inlines), ..rest]) -> {\n       use details <- default_blocks(rest)\n       use summary <- default_inlines(inlines)\n       // `details` and `summary` are Lustre elements that can be used as building blocks:\n       html.details([], [\n         html.summary([], [summary]),\n         details,\n       ])\n       |> custom\n     }\n     _ -> default\n   }\n }\n ```\n","deprecation":null,"implementations":{"gleam":true,"uses-erlang-externals":true,"uses-javascript-externals":false,"can-run-on-erlang":true,"can-run-on-javascript":true},"parameters":[{"label":null,"type":{"kind":"named","name":"List","package":"","module":"gleam","parameters":[{"kind":"named","name":"Inline","package":"pandi","module":"pandi/doc","parameters":[]}]}},{"label":null,"type":{"kind":"fn","parameters":[{"kind":"named","name":"Element","package":"lustre","module":"lustre/vdom/vnode","parameters":[{"kind":"variable","id":0}]}],"return":{"kind":"named","name":"Action","package":"pandoc_lustre_converter","module":"pandoc_lustre_converter","parameters":[{"kind":"variable","id":0}]}}}],"return":{"kind":"named","name":"Action","package":"pandoc_lustre_converter","module":"pandoc_lustre_converter","parameters":[{"kind":"variable","id":0}]}}}}}}